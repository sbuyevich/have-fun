@using HaveFun.Core
@namespace HaveFun.Web

<MudNavMenu>
    @if (CurrentUserState.CurrentUser is { } currentUser)
    {
        <MudNavLink Href="/home"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Home">
            Home
        </MudNavLink>

        @foreach (var game in AvailableGames.Games)
        {
            <MudNavLink Href="@GetGameHref(currentUser, game)"
                        Icon="@Icons.Material.Filled.SportsEsports"
                        Disabled="@(currentUser.Role != JoinRole.Master)"
                        OnClick="@(() => SelectGameAsync(currentUser, game))">
                @game.DisplayName
            </MudNavLink>
        }
    }
</MudNavMenu>
