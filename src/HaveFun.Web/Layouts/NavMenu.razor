@using HaveFun.Core
@namespace HaveFun.Web
@implements IDisposable
@inject ICurrentUserStateService CurrentUserState

<MudNavMenu>
    @if (CurrentUserState.CurrentUser is { } currentUser)
    {
        <MudNavLink Href="/home"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Home">
            Home
        </MudNavLink>

        @if (currentUser.Role == JoinRole.Master)
        {
            <MudNavLink Href="/dashboard"
                        Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
        }
        else if (currentUser.Role == JoinRole.Player)
        {
            <MudNavLink Href="/player"
                        Icon="@Icons.Material.Filled.SportsEsports">
                Player
            </MudNavLink>
        }
    }
</MudNavMenu>

@code {
    protected override void OnInitialized()
    {
        CurrentUserState.Changed += HandleCurrentUserChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await CurrentUserState.InitializeAsync();
    }

    private void HandleCurrentUserChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CurrentUserState.Changed -= HandleCurrentUserChanged;
    }
}
