@namespace HaveFun.Web
@inherits LayoutComponentBase
@inject IUserSessionStorageService UserSessionStorage

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       Variant="Variant.Text"
                       OnClick="ToggleNavigation"
                       aria-label="Navigation menu" />
        <MudText Typo="Typo.h6" Class="ml-2">HAVE FUN</MudText>
        <MudSpacer />
        <MudText Typo="Typo.h6" Class="ml-2">Hi, @CurrentUserName.ToUpper()</MudText>
        <MudSpacer />
        <MudItem xs="12" md="4" Class="d-flex justify-end" Style="width:50px;">
            <img class="home-avatar home-avatar--master"
                 src="/images/master-avatar.svg"
                 alt="Master avatar" />
        </MudItem>
    </MudAppBar>

    @if (isNavigationOpen)
    {
        <MudDrawer Open="true"
                   ClipMode="DrawerClipMode.Always"
                   Elevation="1"
                   Variant="DrawerVariant.Persistent">
            <NavMenu />
        </MudDrawer>
    }

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private string CurrentUserName = string.Empty;
    private bool isNavigationOpen = true;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }
        CurrentUserName = (await UserSessionStorage.GetCurrentUserAsync())?.Name ?? string.Empty;
        StateHasChanged();
    }

    private void ToggleNavigation()
    {
        isNavigationOpen = !isNavigationOpen;
    }
}
