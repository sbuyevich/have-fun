@namespace HaveFun.Web
@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       Variant="Variant.Text"
                       OnClick="ToggleNavigation"
                       aria-label="Navigation menu" />
        <MudText Typo="Typo.h6" Class="ml-2">HAVE FUN</MudText>
        <MudSpacer />
        @if (CurrentUserState.CurrentUser is not null)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.h6">Hi, @CurrentUserName.ToUpperInvariant()</MudText>
                <MudAvatar Size="Size.Medium" Class="app-bar-avatar">
                    <img src="@CurrentUserAvatarUrl"
                         alt="Current user avatar" />
                </MudAvatar>
            </MudStack>
        }
    </MudAppBar>

    @if (isNavigationOpen)
    {
        <MudDrawer Open="true"
                   ClipMode="DrawerClipMode.Always"
                   Elevation="1"
                   Variant="DrawerVariant.Persistent">
            <NavMenu />
        </MudDrawer>
    }

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>
