@page "/"
@namespace HaveFun.Web

<PageTitle>Have-Fun</PageTitle>

<MudStack Spacing="4">
    <MudPaper Class="pa-6" Elevation="0" Outlined="true">
        <MudStack Spacing="2">
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                Local server running
            </MudAlert>
            <MudText Typo="Typo.h3">Have-Fun</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                Host a browser game for friends on the same local network.
            </MudText>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Join URLs</MudText>

                <MudStack Spacing="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle2">Join from another device</MudText>
                        @if (LanUrl is null)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                LAN address was not detected. Check this computer's network connection.
                            </MudText>
                        }
                        else
                        {
                            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                                <MudText Typo="Typo.body2"><code>@LanUrl</code></MudText>
                            </MudPaper>
                        }
                    </MudStack>

                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle2">Host computer only</MudText>
                        <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.body2"><code>@LocalhostUrl</code></MudText>
                        </MudPaper>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Stage 1 Status</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.CheckCircle">Blazor InteractiveServer is configured.</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.CheckCircle">@SentenceCount predefined sentences loaded.</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.CheckCircle">No database or cloud service is required.</MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6">Name entry comes next</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Stage 2 will add the shared name input here and route the configured master name to the dashboard.
        </MudText>
    </MudPaper>
</MudStack>
