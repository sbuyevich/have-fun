@page "/home"
@using HaveFun.Core
@namespace HaveFun.Web

<PageTitle>Have-Fun Home</PageTitle>

@if (!IsSessionChecked)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
        Checking session
    </MudAlert>
}
else if (IsMaster)
{
    <HomeMaster CurrentUserName="@CurrentUser?.Name"
                SharedJoinUrl="@SharedJoinUrl"
                QrCodeDataUri="@QrCodeDataUri"
                Players="@Players"
                OnRefreshPlayers="RefreshPlayers" />
}
else if (IsPlayer)
{
    <HomePlayer CurrentUserName="@CurrentUser?.Name"
                Avatars="@Avatars"
                SelectedAvatarFileName="@SelectedAvatarFileName"
                SelectedAvatarFileNameChanged="SelectAvatarAsync" />
}
else
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
        This session has an unknown role. Join again to continue.
    </MudAlert>
    <MudButton Href="/"
               Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Login">
        Join
    </MudButton>
}
