@page "/player-sentence-scrambler"
@layout RegisterLayout
@namespace HaveFun.Web

<PageTitle>Player Sentence Scrambler</PageTitle>

<MudStack Spacing="4" Class="pa-4">
    @if (!IsSessionChecked)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Checking player session
        </MudAlert>
    }
    else if (ErrorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @ErrorMessage
        </MudAlert>
        <MudButton Href="/register"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Login">
            Register
        </MudButton>
    }
    else if (CurrentRound is not null)
    {
        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h5">Sentence Scrambler Game</MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                    Rearrange available sentences below to make a correct sentence.
                </MudText>
            </MudStack>
        </MudPaper>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.h6" Class="mb-4">Round Status</MudText>
                    <MudChip T="string" Color="@RoundStatusColor" Variant="Variant.Outlined">
                        @CurrentRound.Status
                    </MudChip>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">
                        @CurrentRound.TimeLimitInSeconds seconds
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.h6" Class="mb-4">Timer</MudText>
                    <MudText Typo="Typo.h4">@RemainingTimeText</MudText>
                    @if (IsTimerExpired)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error">
                            Time is up
                        </MudText>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 h-100" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.h6" Class="mb-4">Sentences</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @AvailableSentenceCount available
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudText Typo="Typo.h6" Class="mb-4">Collected Sentence</MudText>
            @if (PlayerRoundState is null || PlayerRoundState.CollectedSentences.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Click sentences below to build your sentence.
                </MudText>
            }
            else
            {
                <MudStack Row="true" Spacing="2" Class="flex-wrap">
                    @foreach (var sentence in PlayerRoundState.CollectedSentences)
                    {
                        <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled">
                            @sentence.Text
                        </MudChip>
                    }
                </MudStack>
            }
        </MudPaper>

        @if (PlayerRoundState?.IsSubmitted == true)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                Submitted: @PlayerRoundState.SubmittedSentence
                @if (PlayerRoundState.SpentTime is not null)
                {
                    <span> (@FormatSpentTime(PlayerRoundState.SpentTime.Value))</span>
                }
            </MudAlert>
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Available Sentences</MudText>
                @if (PlayerRoundState is null || PlayerRoundState.AvailableSentences.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        All sentences are selected. Submit when ready.
                    </MudText>
                }
                else
                {
                    <MudStack Row="true" Spacing="2" Class="flex-wrap">
                        @foreach (var sentence in PlayerRoundState.AvailableSentences)
                        {
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       OnClick="@(() => SelectSentence(sentence.Id))">
                                @sentence.Text
                            </MudButton>
                        }
                    </MudStack>
                }
            </MudPaper>

            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Check"
                       Disabled="@(!CanSubmit)"
                       OnClick="SubmitRound">
                Submit
            </MudButton>
        }
    }
</MudStack>
