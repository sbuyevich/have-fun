@page "/register"
@layout RegisterLayout
@namespace HaveFun.Web

<PageTitle>Join Have-Fun</PageTitle>

<main class="register-page">
    <section class="register-hero" aria-label="Join Have-Fun">
        <MudPaper Class="register-panel pa-6" Elevation="8">
            <MudStack Spacing="4">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h3">Have-Fun</MudText>
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                        Enter your name to join the local game.
                    </MudText>
                </MudStack>

                <form @onsubmit="JoinAsync" @onsubmit:preventDefault="true">
                    <MudStack Spacing="2">
                        <MudTextField @bind-Value="_submittedName"
                                      Label="Name"
                                      Variant="Variant.Outlined"
                                      Error="@(_validationError is not null)"
                                      ErrorText="@_validationError"
                                      Immediate="true"
                                      AutoFocus="true" />
                        <MudButton ButtonType="ButtonType.Submit"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Login"
                                   Disabled="@_isJoining">
                            Join
                        </MudButton>
                    </MudStack>
                </form>

                @if (_lanUrl is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Player URL: <code>@_lanUrl</code>
                    </MudText>
                }
            </MudStack>
        </MudPaper>
    </section>
</main>
